<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:AvaloniaApplication.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="{x:Type viewModels:HomeViewModel}"
             x:Class="AvaloniaApplication.Views.HomeView">

	<!-- <StackPanel> -->
	<!-- 	<Button Command="{Binding ShowDialogCommand}" Content="Shoe Dialog" /> -->
	<!-- </StackPanel> -->

	<DockPanel LastChildFill="True">
		<UniformGrid Columns="2">
			<Button Content="Home" />
			<Button Content="User" />
		</UniformGrid>
		<Grid>
			<TextBlock Text="hello" />
		</Grid>
	</DockPanel>
</UserControl>
