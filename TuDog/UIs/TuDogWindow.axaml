<uIs:TuDogWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:uIs="clr-namespace:TuDog.UIs"
                 xmlns:bootstrap="clr-namespace:TuDog.Bootstrap;assembly=TuDog"
                 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                 x:Class="TuDog.UIs.TuDogWindow"
                 x:DataType="bootstrap:TuDogWindowViewModelBase"
                 WindowState="{Binding WindowState, Mode=TwoWay}"
                 WindowDecorations="None">

    <Window.Template>
        <ControlTemplate>
            <Grid RowDefinitions="Auto,*" Background="DarkGray">
                <Border Grid.Row="0" x:Name="PART_TitleBar">
                    <ContentControl Template="{TemplateBinding TitleBarTemplate}" />
                </Border>
                <ContentPresenter Grid.Row="1" Content="{TemplateBinding Content}" />

                <uIs:InfoBox Grid.RowSpan="2" VerticalAlignment="Top" x:Name="PART_InfoBox" HorizontalAlignment="Right"
                             Margin="0,5,5,0" />
            </Grid>
        </ControlTemplate>
    </Window.Template>
</uIs:TuDogWindow>
